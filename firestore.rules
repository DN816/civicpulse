rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasRole(role) {
      return isSignedIn() && request.auth.token.role == role;
    }

    function isModerator() {
      return hasRole('moderator');
    }

    function isAuthority() {
      return hasRole('authority');
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'role', 'display_name', 'email', 'verified_account', 'trust_score', 'total_points', 'created_at'])
        && data.id == request.auth.uid
        && data.role == 'citizen'
        && data.display_name is string && data.display_name.size() <= 100
        && data.email is string && data.email.size() <= 150
        && data.verified_account is bool
        && data.trust_score is int && data.trust_score >= 0 && data.trust_score <= 100
        && data.total_points is int && data.total_points >= 0;
    }

    function isValidReport(data) {
      return data.keys().hasAll(['id', 'citizen_id', 'category', 'severity', 'status', 'photo_url', 'lat', 'lng', 'device_timestamp', 'created_at', 'updated_at'])
        && data.citizen_id == request.auth.uid
        && data.category is string && data.category.size() <= 50
        && data.severity in ['Low', 'Medium', 'High']
        && data.status == 'NEW'
        && data.photo_url is string && data.photo_url.size() <= 1000
        && data.lat is float || data.lat is int
        && data.lng is float || data.lng is int
        && (!('geo_accuracy_meters' in data) || data.geo_accuracy_meters is float || data.geo_accuracy_meters is int)
        && (!('geo_accuracy_unknown' in data) || data.geo_accuracy_unknown is bool);
    }

    function isModeratorLockClaim() {
      return isModerator()
        && resource.data.status == 'IN_REVIEW'
        && request.resource.data.moderator_id == request.auth.uid
        && request.resource.data.locked_until is timestamp
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['moderator_id', 'locked_until'])
        && (
          !('locked_until' in resource.data)
          || resource.data.locked_until == null
          || resource.data.locked_until <= request.time
          || resource.data.moderator_id == request.auth.uid
        );
    }

    function isCitizenClarificationUpdate() {
      return hasRole('citizen')
        && resource.data.citizen_id == request.auth.uid
        && resource.data.status == 'AWAITING_CLARIFICATION'
        && request.resource.data.status == 'NEW'
        && request.resource.data.clarification_answer is string
        && request.resource.data.clarification_answer.size() <= 500
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 5000
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clarification_answer', 'description', 'status']);
    }

    function isValidModeratorAudit(data) {
      return data.keys().hasAll(['report_id', 'moderator_id', 'action', 'reason', 'created_at'])
        && data.moderator_id == request.auth.uid
        && data.report_id is string && data.report_id.size() <= 128
        && data.action is string && data.action.size() <= 50
        && data.reason is string && data.reason.size() <= 2000;
    }

    function isAuthorityClusterStatusUpdate() {
      return isAuthority()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updated_at', 'authority_id', 'after_photo_url'])
        && request.resource.data.status is string
        && request.resource.data.status.size() <= 50
        && request.resource.data.updated_at is timestamp;
    }

    function isAuthorityReportStatusUpdate() {
      return isAuthority()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updated_at', 'authority_id', 'after_photo_url'])
        && request.resource.data.status is string
        && request.resource.data.status.size() <= 50;
    }

    function isCitizenReportResolve() {
      return hasRole('citizen')
        && resource.data.status == 'AWAITING_CONFIRMATION'
        && request.resource.data.status == 'RESOLVED'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updated_at']);
    }

    function isModeratorReportUpdate() {
      return isModerator()
        && resource.data.moderator_id == request.auth.uid
        && (resource.data.locked_until == null || request.time < resource.data.locked_until)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'locked_until', 'moderator_id', 'pii_handled', 'photo_url', 'pii_flag']);
    }

    function isModeratorClusterStatusUpdate() {
      return isModerator()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updated_at']);
    }

    function isValidReportEvent(data) {
      return data.keys().hasAll(['event_type', 'report_id', 'authority_id', 'created_at'])
        && data.event_type is string
        && data.report_id is string && data.report_id.size() <= 128
        && data.authority_id == request.auth.uid;
    }

    function isAssignedAuthorityForReport(reportId) {
      let report = get(/databases/$(database)/documents/reports/$(reportId)).data;
      return !('authority_id' in report)
        || report.authority_id == null
        || report.authority_id == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId)
        && request.resource.data.role == resource.data.role
        && request.resource.data.trust_score == resource.data.trust_score;
      allow delete: if false;
    }

    match /reports/{reportId} {
      allow read: if isSignedIn();
      allow create: if hasRole('citizen') && isValidId(reportId) && isValidReport(request.resource.data);
      allow update: if isModeratorLockClaim()
        || isCitizenClarificationUpdate()
        || isAuthorityReportStatusUpdate()
        || isModeratorReportUpdate()
        || isCitizenReportResolve();
      allow delete: if false;
    }

    match /clusters/{clusterId} {
      allow read: if isSignedIn();
      allow create, delete: if false;
      allow update: if isAuthorityClusterStatusUpdate() || isModeratorClusterStatusUpdate();
    }

    match /report_events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isAuthority()
        && isValidId(eventId)
        && isValidReportEvent(request.resource.data)
        && isAssignedAuthorityForReport(request.resource.data.report_id);
      allow update, delete: if false;
    }

    match /health_reports/{reportId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /escalation_log/{logId} {
      allow read: if isAuthority() || isModerator();
      allow write: if false;
    }

    match /authorities/{authorityId} {
      allow read: if isOwner(authorityId) || isModerator();
      allow write: if false;
    }

    match /moderator_audits/{auditId} {
      allow read: if isModerator();
      allow create: if isModerator() && isValidId(auditId) && isValidModeratorAudit(request.resource.data);
      allow update, delete: if false;
    }

    match /citizen_stats/{userId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /citizen_stats/{userId}/xp_history/{entryId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }
  }
}
